<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org/DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="mymemo">
	<insert id="add"  parameterType="vo.myMemoVO">
		insert into mymemo values(mymemo_seq.nextVal, #{memo}, #{writer}, sysdate)
	</insert>

	<select id="list" resultType="vo.myMemoVO">
		select num, memo, writer, mdate from mymemo order by num desc
	</select>
</mapper>